    private IEnumerable<OrderRow> VisibleOrders => Orders.Where(order =>
        (selectedStatus == "Tout" || order.Status == selectedStatus) &&
        (
            string.IsNullOrWhiteSpace(searchTerm) ||
            order.OrderNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            order.Customer.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            order.Wilaya.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            order.Source.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
        ));

    private void SetStatus(string status)
    {
        selectedStatus = status;
    }

    private sealed record OrderRow(
        string Source,
        string OrderNumber,
        string Date,
        string Customer,
        IReadOnlyList<string> Products,
        string Total,
        string Quantity,
        string ShippingCost,
        string Note,
        string Employee,
        string Wilaya,
        string Phone,
        string DeliveryZone,
        string DeliveryType,
        string Status,
        string SourceClass,
        string StatusClass);
}